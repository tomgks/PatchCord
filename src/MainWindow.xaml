<Window x:Class="PatchCord.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PatchCord" Width="900" Height="620"
        Icon="app.ico"
        FontFamily="pack://application:,,,/fonts/#Space Grotesk"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" ResizeMode="CanMinimize">
  <Window.Resources>
    <SolidColorBrush x:Key="Bg" Color="#1E1F22"/>
    <SolidColorBrush x:Key="Card" Color="#2B2D31"/>
    <SolidColorBrush x:Key="Card2" Color="#313338"/>
    <SolidColorBrush x:Key="Border" Color="#3A3C42"/>
    <SolidColorBrush x:Key="Accent" Color="#5865F2"/>
    <SolidColorBrush x:Key="AccentHover" Color="#4752C4"/>
    <SolidColorBrush x:Key="OnAccent" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Text" Color="#F2F3F5"/>
    <SolidColorBrush x:Key="Sub" Color="#B5BAC1"/>
    <SolidColorBrush x:Key="GhostBg" Color="#383A40"/>
    <SolidColorBrush x:Key="GhostHover" Color="#41434A"/>
    <SolidColorBrush x:Key="Scroll" Color="#4E5058"/>
    <Style x:Key="Pill" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
      <Setter Property="Background" Value="{DynamicResource Accent}"/>
      <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
      <Setter Property="Height" Value="42"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="20,0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate></Setter.Value></Setter>
      <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource AccentHover}"/></Trigger></Style.Triggers>
    </Style>
    <Style x:Key="Ghost" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource Text}"/>
      <Setter Property="Background" Value="{DynamicResource GhostBg}"/>
      <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="12"/>
      <Setter Property="Height" Value="38"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource Border}" BorderThickness="1" Padding="16,0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate></Setter.Value></Setter>
      <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource GhostHover}"/></Trigger></Style.Triggers>
    </Style>
    <Style x:Key="WinBtn" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource Sub}"/><Setter Property="Background" Value="Transparent"/>
      <Setter Property="Width" Value="46"/><Setter Property="Height" Value="46"/><Setter Property="FontSize" Value="14"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="b" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
          <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource GhostBg}"/></Trigger></ControlTemplate.Triggers>
        </ControlTemplate></Setter.Value></Setter>
    </Style>
    <!-- themed scrollbar: thin, rounded thumb, no arrow buttons -->
    <Style x:Key="ScrollThumb" TargetType="{x:Type Thumb}">
      <Setter Property="OverridesDefaultStyle" Value="true"/>
      <Setter Property="IsTabStop" Value="false"/>
      <Setter Property="Background" Value="{DynamicResource Scroll}"/>
      <Setter Property="MinHeight" Value="28"/>
      <Setter Property="Template"><Setter.Value>
        <ControlTemplate TargetType="{x:Type Thumb}">
          <Border CornerRadius="4" Background="{TemplateBinding Background}" Margin="2,0"/>
        </ControlTemplate></Setter.Value></Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource Accent}"/></Trigger>
        <Trigger Property="IsDragging" Value="True"><Setter Property="Background" Value="{DynamicResource Accent}"/></Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ScrollHidden" TargetType="{x:Type RepeatButton}">
      <Setter Property="OverridesDefaultStyle" Value="true"/>
      <Setter Property="Focusable" Value="false"/><Setter Property="IsTabStop" Value="false"/>
      <Setter Property="Template"><Setter.Value>
        <ControlTemplate TargetType="{x:Type RepeatButton}"><Border Background="Transparent"/></ControlTemplate>
      </Setter.Value></Setter>
    </Style>
    <Style TargetType="{x:Type ScrollBar}">
      <Setter Property="OverridesDefaultStyle" Value="true"/>
      <Setter Property="Width" Value="11"/>
      <Setter Property="Template"><Setter.Value>
        <ControlTemplate TargetType="{x:Type ScrollBar}">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="true">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource ScrollHidden}" Command="{x:Static ScrollBar.PageUpCommand}"/>
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource ScrollThumb}"/>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource ScrollHidden}" Command="{x:Static ScrollBar.PageDownCommand}"/>
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
        </ControlTemplate></Setter.Value></Setter>
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Width" Value="Auto"/><Setter Property="Height" Value="11"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>
  <Border Margin="12" CornerRadius="8" Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1">
    <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.4" Color="#000000"/></Border.Effect>
    <Grid>
      <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
      <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
          <Border x:Name="TitleDot" Width="9" Height="9" CornerRadius="2" Background="{DynamicResource Accent}"/>
          <TextBlock Text="PATCH" Foreground="{DynamicResource Text}" FontSize="14" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
          <TextBlock Text="CORD" Foreground="{DynamicResource Accent}" FontSize="14" FontWeight="Bold" Margin="3,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="BtnMin" Style="{StaticResource WinBtn}" Content="&#x2013;"/>
          <Button x:Name="BtnClose" Style="{StaticResource WinBtn}" Content="&#x2715;"/>
        </StackPanel>
        <Border x:Name="TitleUnderline" Height="2" VerticalAlignment="Bottom" Background="{DynamicResource Border}" Margin="0,0,0,0"/>
      </Grid>
      <!-- tab bar -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,2,0,8">
        <Border x:Name="TabStatus" Cursor="Hand" Padding="2,6" Margin="0,0,24,0" BorderThickness="0,0,0,2" BorderBrush="Transparent">
          <TextBlock x:Name="TabStatusText" Text="Status" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Sub}"/>
        </Border>
        <Border x:Name="TabOptions" Cursor="Hand" Padding="2,6" BorderThickness="0,0,0,2" BorderBrush="Transparent">
          <TextBlock x:Name="TabOptionsText" Text="Options" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Sub}"/>
        </Border>
      </StackPanel>

      <Grid Grid.Row="2">
        <!-- STATUS TAB -->
        <ScrollViewer x:Name="StatusScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="20,2,20,18">
          <StackPanel>
            <Grid Margin="2,8,0,8">
                <StackPanel>
                  <TextBlock Text="Monitoring" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium"/>
                  <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                    <Border x:Name="StatusDot" Width="10" Height="10" CornerRadius="5" Background="#23A55A" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Active" Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Margin="9,0,0,0"/>
                  </StackPanel>
                  <TextBlock x:Name="StatusSub" Text="Watching for Discord updates..." Foreground="{DynamicResource Sub}" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
                <Button x:Name="BtnToggle" Style="{StaticResource Pill}" Content="Turn Off" HorizontalAlignment="Right" VerticalAlignment="Center" Width="112"/>
            </Grid>
            <Border x:Name="ModWarn" Visibility="Collapsed" Margin="0,12,0,0" Padding="14,11" CornerRadius="6" Background="#1F1A0A" BorderBrush="#FAA61A" BorderThickness="1">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="&#x26A0;" Foreground="#FAA61A" FontSize="15" FontWeight="Bold" VerticalAlignment="Top" Margin="0,0,10,0"/>
                  <TextBlock x:Name="ModWarnText" Foreground="#FAD27A" FontSize="12.5" TextWrapping="Wrap" MaxWidth="620"/>
                </StackPanel>
                <Button x:Name="BtnGetMod" Grid.Column="1" Content="Get Vencord" Height="32" Cursor="Hand" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#1A1206" FontSize="12" FontWeight="SemiBold">
                  <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="gb" CornerRadius="8" Background="#FAA61A" Padding="16,0"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="gb" Property="Background" Value="#FFB733"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
              </Grid>
            </Border>
            <TextBlock Text="Discord installs" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" Margin="2,24,0,10"/>
            <StackPanel x:Name="InstallList"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
              <Button x:Name="BtnDetectDiscord" Style="{StaticResource Ghost}" Content="Detect Discord"/>
              <Button x:Name="BtnDetectPTB" Style="{StaticResource Ghost}" Content="Detect PTB" Margin="10,0,0,0"/>
              <Button x:Name="BtnAddCustom" Style="{StaticResource Ghost}" Content="Add custom path..." Margin="10,0,0,0"/>
            </StackPanel>

            <TextBlock Text="Activity" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" Margin="2,24,0,10"/>
            <Border Background="{DynamicResource Card2}" CornerRadius="4" Padding="14" Height="130">
              <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" Foreground="{DynamicResource Sub}" FontFamily="pack://application:,,,/fonts/#JetBrains Mono" FontSize="11" TextWrapping="Wrap"/>
              </ScrollViewer>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- OPTIONS TAB -->
        <ScrollViewer x:Name="OptionsScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="20,2,20,18">
          <StackPanel>
            <TextBlock Text="Client mod" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" Margin="4,4,0,6"/>
            <TextBlock Text="Pick one mod to keep injected after Discord updates — only one client mod can be active at a time. OpenAsar (below) is separate and stacks under any of them." Foreground="{DynamicResource Sub}" FontSize="12" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left" Margin="4,0,0,12"/>
            <StackPanel x:Name="ClientModPanel"/>
            <Border x:Name="ModWarnOpt" Visibility="Collapsed" Margin="0,2,0,0" Padding="14,11" CornerRadius="6" Background="#1F1A0A" BorderBrush="#FAA61A" BorderThickness="1">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="&#x26A0;" Foreground="#FAA61A" FontSize="15" FontWeight="Bold" VerticalAlignment="Top" Margin="0,0,10,0"/>
                  <TextBlock x:Name="ModWarnOptText" Foreground="#FAD27A" FontSize="12.5" TextWrapping="Wrap" MaxWidth="520"/>
                </StackPanel>
                <Button x:Name="BtnGetModOpt" Grid.Column="1" Content="Get Vencord" Height="32" Cursor="Hand" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#1A1206" FontSize="12" FontWeight="SemiBold">
                  <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="gb2" CornerRadius="8" Background="#FAA61A" Padding="16,0"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="gb2" Property="Background" Value="#FFB733"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
              </Grid>
            </Border>

            <TextBlock Text="OpenAsar" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" Margin="4,28,0,8"/>
            <Grid Margin="2,0,0,0">
              <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="Keep OpenAsar installed" Foreground="{DynamicResource Text}" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Open-source replacement for Discord's app.asar (by GooseMod) — faster, lighter startup. Separate project from Vencord/Equicord; stacks under whichever mod you pick. Downloaded from its official GitHub releases." Foreground="{DynamicResource Sub}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
              </StackPanel>
              <Button x:Name="BtnOpenAsarGlobal" Width="62" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="White" FontSize="11" FontWeight="SemiBold" Cursor="Hand">
                <Button.Template><ControlTemplate TargetType="Button"><Border CornerRadius="8" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
              </Button>
            </Grid>

            <TextBlock Text="Startup" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" Margin="4,28,0,8"/>
            <Grid Margin="2,0,0,0">
              <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="Run at startup" Foreground="{DynamicResource Text}" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Open PatchCord automatically when you sign in to Windows, so it's always keeping your mod patched." Foreground="{DynamicResource Sub}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
              </StackPanel>
              <Button x:Name="BtnStartup" Width="62" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="White" FontSize="11" FontWeight="SemiBold" Cursor="Hand">
                <Button.Template><ControlTemplate TargetType="Button"><Border CornerRadius="8" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
              </Button>
            </Grid>

            <TextBlock Text="Check interval" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" Margin="4,28,0,8"/>
            <Grid Margin="2,0,0,0">
              <TextBlock Text="How often to check your installs for re-patching" Foreground="{DynamicResource Sub}" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock x:Name="LblInterval" Foreground="{DynamicResource Text}" FontSize="12" HorizontalAlignment="Right"/>
            </Grid>
            <Slider x:Name="SliderInterval" Minimum="5" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>

            <Border x:Name="BtnAppearanceToggle" Cursor="Hand" Background="Transparent" Margin="0,28,0,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="AppearanceChevron" Text="&#x25B8;" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" Margin="4,0,7,0"/>
                <TextBlock Text="Appearance &amp; notifications" Foreground="{DynamicResource Sub}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <StackPanel x:Name="AppearancePanel" Visibility="Collapsed" Margin="2,14,0,2">
              <Grid>
                <TextBlock Text="Show notifications" Foreground="{DynamicResource Text}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="BtnNotifyToggle" Width="62" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="SemiBold" Cursor="Hand">
                  <Button.Template><ControlTemplate TargetType="Button"><Border CornerRadius="8" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
              </Grid>
              <TextBlock Text="Theme" Foreground="{DynamicResource Sub}" FontSize="12" Margin="0,18,0,9"/>
              <StackPanel x:Name="ThemePanel" Orientation="Horizontal"/>
              <TextBlock Text="Notification style" Foreground="{DynamicResource Sub}" FontSize="12" Margin="0,18,0,9"/>
              <StackPanel x:Name="StylePanel" Orientation="Horizontal"/>
              <Grid Margin="0,18,0,0">
                <TextBlock Text="Notification size" Foreground="{DynamicResource Sub}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblNotifyScale" Foreground="{DynamicResource Text}" FontSize="12" HorizontalAlignment="Right"/>
              </Grid>
              <Slider x:Name="SliderNotifyScale" Minimum="70" Maximum="150" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
              <Grid Margin="0,12,0,0">
                <TextBlock Text="Notification duration" Foreground="{DynamicResource Sub}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblNotifyDur" Foreground="{DynamicResource Text}" FontSize="12" HorizontalAlignment="Right"/>
              </Grid>
              <Slider x:Name="SliderNotifyDur" Minimum="3" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
              <Button x:Name="BtnTestNotify" Style="{StaticResource Ghost}" Content="Preview notification" HorizontalAlignment="Left" Margin="0,18,0,0"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>
</Window>
